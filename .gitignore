# Build outputs
/build/
/out/
/.vs/

# CMake generated files outside build directories
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake

# Visual Studio user/local files
*.user
*.suo
*.VC.db
*.VC.VC.opendb
*.opensdf
*.sdf

# Compiler/linker outputs
*.exe
*.ilk
*.obj
*.pdb
*.lib
*.exp
*.dll

# Handoff/reference payloads kept out of the canonical source tree
/TheDawning_Codex_Handoff_v3_unpacked/
*.zip

# Local parallel-agent worktrees and scratch state
/.agents/

# Logs and temp files
*.log
*.tmp
*.bak

# Smoke-test capture output
smoke_capture.ppm
*.ppm

# Secrets. NEVER commit API keys - this repository is PUBLIC.
# Meshy and any other service credentials live in a local .env that git ignores;
# tools read them from the environment, never from a tracked file.
.env
.env.*
!.env.example
secrets/
*.key

# Generated assets: binaries stay OUT of git history.
# This repository is public and git history is permanent, so committing many-MB
# AI-generated GLBs and 4K textures is a decision that cannot be walked back.
# Manifests ARE tracked, so what was generated and with which parameters stays
# reproducible and reviewable. Revisit with Git LFS if binaries need to ship.
assets/generated/**/*.glb
assets/generated/**/*.fbx
assets/generated/**/*.png
